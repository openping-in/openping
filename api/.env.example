APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/openping
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_COOKIE_NAME=access_token

# Cookie flags are derived from APP_ENV when unset:
#   development -> Secure=false, SameSite=lax  (http://localhost)
#   production  -> Secure=true,  SameSite=none  (https, cross-origin SPA)